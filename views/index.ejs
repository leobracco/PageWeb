<script>
function gtag_report_conversion(url) {
  var callback = function () {
    if (typeof(url) != 'undefined') {
      window.open(url, '_blank');
    }
  };
    // Generamos un número aleatorio para simular un ID de transacción
  var randomTransactionId = Math.floor(Math.random() * 1000000000);
  gtag('event', 'conversion', {
      'send_to': 'AW-17933689832/5I3ZCKq7hvQbEOjHuedC',
      'value': 1.0,
      'transaction_id': randomTransactionId,
      'currency': 'ARS',
      'event_callback': callback
  });
  return false;
}
</script>
