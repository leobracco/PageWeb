<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{
    "@type": "ListItem",
    "position": 1,
    "name": "Inicio",
    "item": "https://agroparallel.com/"
  },{
    "@type": "ListItem",
    "position": 2,
    "name": "Productos",
    "item": "https://agroparallel.com/productos"
  },{
    "@type": "ListItem",
    "position": 3,
    "name": "<%= producto.Nombre %>",
    "item": "https://agroparallel.com/producto/<%= producto.id %>"
  }]
}
</script>

<section class="bg-light py-5">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Inicio</a></li>
        <li class="breadcrumb-item"><a href="/productos">Productos</a></li>
        <li class="breadcrumb-item active" aria-current="page"><%= producto.Nombre %></li>
    </ol>
</nav>

        <div class="row">
            <div class="col-lg-5 mb-4">
                <div class="card shadow-sm border-0">
                    <picture>
                        <source srcset="/<%= producto.Imagen.replace(/\.(jpg|png)$/, '.webp') %>" type="image/webp">
                        <img src="/<%= producto.Imagen %>" 
                             class="img-fluid rounded card-img-top" 
                             alt="Tecnología de precisión Agro Parallel: <%= producto.Nombre %>"
                             loading="eager" 
                             decoding="async"
                             width="600" 
                             height="600">
                    </picture>
                </div>
            </div>

            <div class="col-lg-7">
                <div class="ps-lg-4">
                    <h1 class="display-5 text-success fw-bold mb-2"><%= producto.Nombre %></h1>
                    <p class="text-muted mb-4"><i class="fas fa-tag me-2"></i><%= producto.Categoria %></p>
                    
                    <div class="bg-white p-4 rounded shadow-sm mb-4">
                        <p class="h3 text-dark fw-bold mb-0">U$S <%= producto.Precio %></p>
                        <small class="text-muted">* Sujeto a condiciones comerciales</small>
                    </div>

                    <ul class="nav nav-tabs border-0" id="productTab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <a class="nav-link active fw-bold border-0 text-success" id="desc-tab" data-bs-toggle="tab" href="#desc" role="tab">Descripción</a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a class="nav-link fw-bold border-0 text-dark" id="specs-tab" data-bs-toggle="tab" href="#specs" role="tab">Ficha Técnica</a>
                        </li>
                    </ul>

                    <div class="tab-content bg-white p-4 border rounded-bottom shadow-sm" id="productTabContent">
                        <div class="tab-pane fade show active" id="desc" role="tabpanel">
                            <div class="lh-lg text-secondary">
                                <%= producto.DescripcionLarga %>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="specs" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <tbody>
                                        <% if (producto.Especificaciones && Object.keys(producto.Especificaciones).length > 0) { %>
                                            <% Object.entries(producto.Especificaciones).forEach(([key, val]) => { %>
                                                <tr>
                                                    <th class="text-success w-25" scope="row"><%= key %></th>
                                                    <td class="text-secondary"><%= val %></td>
                                                </tr>
                                            <% }) %>
                                        <% } else { %>
                                            <tr>
                                                <td class="text-center py-4 text-muted">
                                                    Consulte especificaciones técnicas detalladas con nuestros asesores.
                                                </td>
                                            </tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <a href="https://wa.me/5492326403502?text=Hola Agro Parallel, me interesa recibir asesoramiento sobre: <%= producto.Nombre %>" 
   onclick="return gtag_report_conversion(this.href);"
   class="btn btn-success btn-lg py-3 shadow-lg fw-bold"
   target="_blank"
   rel="noopener noreferrer">
    <i class="fab fa-whatsapp fa-lg me-2"></i> Consultar a un Especialista
</a>
                </div>
            </div>
        </div>
    </div>
</section>

<% if (typeof productosMenu !== 'undefined') { %>
    <%- include('./relacionados.ejs', { actual: producto.id }) %>
<% } %>