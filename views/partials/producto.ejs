<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [{
    "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://agroparallel.com/"
  },{
    "@type": "ListItem", "position": 2, "name": "Productos", "item": "https://agroparallel.com/productos"
  },{
    "@type": "ListItem", "position": 3,
    "name": "<%= producto.Nombre %>",
    "item": "https://agroparallel.com/producto/<%= producto._id || producto.id %>"
  }]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "<%= producto.Nombre %>",
  "description": "<%= (producto.DescripcionLarga || '').replace(/"/g, '&quot;') %>",
  "image": "https://agroparallel.com/<%= producto.Imagen %>",
  "sku": "<%= producto._id || producto.id %>",
  "brand": { "@type": "Brand", "name": "Agro Parallel" },
  "category": "<%= producto.Categoria %>",
  "url": "https://agroparallel.com/producto/<%= producto._id || producto.id %>",
  <% if (producto.Precio && producto.Precio !== 'Consultar') { %>
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "price": "<%= producto.Precio.replace(/[^0-9.]/g, '') %>",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "Organization", "name": "Agro Parallel" },
    "areaServed": "AR",
    "url": "https://agroparallel.com/producto/<%= producto._id || producto.id %>"
  }
  <% } else { %>
  "offers": {
    "@type": "Offer",
    "availability": "https://schema.org/InStock",
    "priceSpecification": { "@type": "PriceSpecification", "description": "Consultar precio" },
    "seller": { "@type": "Organization", "name": "Agro Parallel" },
    "url": "https://agroparallel.com/producto/<%= producto._id || producto.id %>"
  }
  <% } %>
}
</script>

<section class="agp-section" style="padding-top:40px">

  <!-- Breadcrumb -->
  <nav class="agp-breadcrumb" aria-label="Breadcrumb">
    <a href="/">Inicio</a> / <a href="/productos">Productos</a> / <span><%= producto.Nombre %></span>
  </nav>

  <div class="row g-5">

    <!-- Imagen -->
    <div class="col-lg-5">
      <div class="product-detail-img">
        <picture>
          <source srcset="/<%= producto.Imagen.replace(/\.(jpg|png)$/, '.webp') %>" type="image/webp">
          <img src="/<%= producto.Imagen %>"
               alt="<%= producto.Nombre %> — Agro Parallel"
               loading="eager" decoding="async" width="600" height="600">
        </picture>
      </div>
    </div>

    <!-- Info -->
    <div class="col-lg-7">
      <span class="agp-badge mb-3"><%= producto.Categoria %></span>
      <h1 style="font-family:'Barlow Condensed',sans-serif;font-size:2.8rem;font-weight:900;color:var(--dark);line-height:1;margin-bottom:16px">
        <%= producto.Nombre %>
      </h1>

      <% if (producto.Tags && producto.Tags.length > 0) { %>
        <div class="product-tags">
          <% producto.Tags.forEach(tag => { %><span class="product-tag"><%= tag %></span><% }) %>
        </div>
      <% } %>

      <div class="product-price-box">
        <div class="price-label">Precio</div>
        <div class="price-value">
          <% if (producto.Precio === 'Consultar' || !producto.Precio) { %>
            Consultar
          <% } else { %>
            U$S <%= producto.Precio %>
          <% } %>
        </div>
        <small style="color:var(--muted);font-size:.8rem">* Sujeto a condiciones comerciales</small>
      </div>

      <!-- Tabs -->
      <div class="agp-tabs" role="tablist">
        <button class="agp-tab-btn active" role="tab" aria-selected="true"
                onclick="showTab(event,'tab-desc')">Descripción</button>
        <button class="agp-tab-btn" role="tab" aria-selected="false"
                onclick="showTab(event,'tab-specs')">Ficha Técnica</button>
      </div>

      <div id="tab-desc" class="agp-tab-panel active">
        <p style="line-height:1.8;color:var(--dark)"><%= producto.DescripcionLarga %></p>
      </div>
      <div id="tab-specs" class="agp-tab-panel">
        <% if (producto.Especificaciones && Object.keys(producto.Especificaciones).length > 0) { %>
          <table class="specs-table">
            <tbody>
              <% Object.entries(producto.Especificaciones).forEach(([k,v]) => { %>
              <tr>
                <td><%= k %></td>
                <td><%= v %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <p style="color:var(--muted)">Consultá las especificaciones con nuestros asesores.</p>
        <% } %>
      </div>

      <div class="mt-4">
        <a href="https://wa.me/5492326403502?text=Hola%20Agro%20Parallel%2C%20me%20interesa%20el%20producto%3A%20<%= encodeURIComponent(producto.Nombre) %>"
           onclick="return gtag_report_conversion(this.href);"
           class="agp-btn agp-btn-primary"
           target="_blank" rel="noopener noreferrer"
           style="font-size:1rem;padding:14px 32px">
          <i class="fab fa-whatsapp me-2"></i> Consultar a un Especialista
        </a>
      </div>
    </div>
  </div>
</section>

<% if (typeof productosMenu !== 'undefined') { %>
  <%- include('./relacionados.ejs', { actual: producto._id || producto.id }) %>
<% } %>

<script>
function showTab(e, id) {
  document.querySelectorAll('.agp-tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.agp-tab-btn').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected','false'); });
  document.getElementById(id).classList.add('active');
  e.currentTarget.classList.add('active');
  e.currentTarget.setAttribute('aria-selected','true');
}
</script>
