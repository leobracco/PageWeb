<nav class="agp-nav" role="navigation" aria-label="Navegación principal">
  <div class="agp-nav-inner">
    <a href="/" class="agp-logo">Agro<span>Parallel</span></a>

    <button class="agp-nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <ul class="agp-nav-links" id="navLinks" role="list">
      <li><a href="/">Inicio</a></li>

      <li class="agp-dropdown">
        <a href="/productos" aria-haspopup="true">Productos ▾</a>
        <div class="agp-dropdown-menu" role="menu">
          <div class="agp-dropdown-menu-inner">
            <a href="/productos" class="agp-dropdown-all">Ver todo el catálogo</a>
            <div class="agp-dropdown-divider"></div>
            <% if (typeof productosMenu !== 'undefined') {
                const cats = [...new Set(productosMenu.map(p => p.Categoria))];
                cats.forEach(cat => { %>
                  <div class="agp-dropdown-header"><%= cat %></div>
                  <% productosMenu.filter(p => p.Categoria === cat).forEach(prod => { %>
                    <a href="/producto/<%= prod._id || prod.id %>" role="menuitem"><%= prod.Nombre %></a>
                  <% }) %>
            <% })} %>
          </div>
        </div>
      </li>

      <li><a href="/noticias">Noticias</a></li>
      <li><a href="/servicios">Servicios</a></li>
      <li><a href="/nosotros">Nosotros</a></li>
      <li><a href="/contacto">Contacto</a></li>
    </ul>
  </div>
</nav>

<script>
(function() {
  var btn = document.getElementById('navToggle');
  var links = document.getElementById('navLinks');
  if (btn && links) {
    btn.addEventListener('click', function() {
      var open = links.classList.toggle('open');
      btn.setAttribute('aria-expanded', open);
    });
  }
})();
</script>
