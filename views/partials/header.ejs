<nav class="navbar navbar-expand-lg navbar-light shadow">
  <div class="container d-flex justify-content-between align-items-center">
    <a class="navbar-brand text-success logo h1 align-self-center" href="/">Agro Parallel</a>
    
    <button 
      class="navbar-toggler border-0" 
      type="button" 
      data-bs-toggle="collapse" 
      data-bs-target="#agroparallel_main_nav"
      aria-label="Abrir menú de navegación"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="align-self-center collapse navbar-collapse flex-fill d-lg-flex justify-content-lg-between" id="agroparallel_main_nav">
      <div class="flex-fill">
        <ul class="nav navbar-nav d-flex justify-content-between mx-lg-auto">
          <li class="nav-item"><a class="nav-link" href="/">Inicio</a></li>
          
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown">Productos</a>
            <ul class="dropdown-menu shadow border-0">
              <li><a class="dropdown-item fw-bold text-success" href="/productos">Ver Todo el Catálogo</a></li>
              <li><hr class="dropdown-divider"></li>
              <% if (typeof productosMenu !== 'undefined') { 
                  const categorias = [...new Set(productosMenu.map(p => p.Categoria))];
                  categorias.forEach(cat => { %>
                    <li class="dropdown-header text-uppercase small text-muted"><%= cat %></li>
                    <% productosMenu.filter(p => p.Categoria === cat).forEach(prod => { %>
                      <li><a class="dropdown-item" href="/producto/<%= prod.id %>"><%= prod.Nombre %></a></li>
                    <% }) %>
              <% })} %>
            </ul>
          </li>

          <li class="nav-item"><a class="nav-link" href="/servicios">Servicios</a></li>
          <li class="nav-item"><a class="nav-link" href="/nosotros">Nosotros</a></li>
          <li class="nav-item"><a class="nav-link" href="/contacto">Contacto</a></li>
        </ul>
      </div>
    </div>
  </div>
</nav>