<div class="agp-section" style="padding-top:48px">

  <div class="row g-4">

    <!-- Sidebar filtros -->
    <div class="col-lg-2 mb-2">
      <div class="filter-sidebar">
        <h5>Categorías</h5>
        <a href="/productos" class="filter-pill <%= !categoriaSeleccionada ? 'active' : '' %>">
          Todas
        </a>
        <%
          const categorias = [...new Set(productos.map(p => p.Categoria))];
          categorias.forEach(cat => {
        %>
        <a href="/productos?categoria=<%= encodeURIComponent(cat) %>"
           class="filter-pill <%= categoriaSeleccionada === cat ? 'active' : '' %>">
          <%= cat %>
        </a>
        <% }); %>
      </div>
    </div>

    <!-- Grid -->
    <div class="col-lg-10">
      <%
        const productosFiltrados = categoriaSeleccionada
          ? productos.filter(p => p.Categoria === categoriaSeleccionada)
          : productos;
      %>
      <% if (productosFiltrados.length === 0) { %>
        <p style="color:var(--muted);padding:48px 0;text-align:center">No hay productos en esta categoría.</p>
      <% } else { %>
        <div class="agp-products-grid">
          <% productosFiltrados.forEach(producto => { %>
            <article class="agp-product-card">
              <!-- Imagen -->
              <div class="card-img">
                <% if (producto.Emoji) { %>
                  <span class="card-emoji" aria-hidden="true"><%= producto.Emoji %></span>
                <% } %>
                <img src="/<%= producto.Imagen %>"
                     alt="<%= producto.Nombre %> — <%= producto.Categoria %> | Agro Parallel"
                     loading="lazy" width="400" height="300">
              </div>
              <!-- Body -->
              <div class="card-body">
                <% if (producto.Badge) { %>
                  <span class="card-badge"><%= producto.Badge %></span>
                <% } %>
                <div class="card-cat"><%= producto.Categoria %></div>
                <h3 class="card-name"><%= producto.Nombre %></h3>
                <p class="card-desc"><%= producto.DescripcionCorta %></p>
                <div class="card-price">
                  <% if (producto.Precio && producto.Precio !== 'Consultar') { %>
                    <strong>USD <%= producto.Precio %></strong>
                  <% } else { %>
                    <span style="color:var(--green)">Consultar precio</span>
                  <% } %>
                </div>
                <% if (producto.Tags && producto.Tags.length > 0) { %>
                  <div class="card-tags">
                    <% producto.Tags.slice(0,2).forEach(t => { %><span class="card-tag"><%= t %></span><% }) %>
                  </div>
                <% } %>
                <a href="/producto/<%= producto._id || producto.id %>"
                   class="agp-btn agp-btn-primary"
                   style="width:100%;text-align:center;margin-top:16px">
                  Ver detalles →
                </a>
              </div>
            </article>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>
</div>
