<footer class="agp-footer" role="contentinfo">
  <div class="agp-footer-inner">

    <!-- Columna 1: Info empresa -->
    <div class="footer-info">
      <div class="footer-logo">Agro<span>Parallel</span></div>
      <p>Tecnología de precisión para el campo argentino.</p>
      <p><span aria-hidden="true">📍</span> San Antonio de Areco, Buenos Aires</p>
      <p><span aria-hidden="true">📞</span> <a href="tel:+5492326403502">+54 2326 403502</a></p>
      <p><span aria-hidden="true">✉️</span> <a href="mailto:info@agroparallel.com">info@agroparallel.com</a></p>
    </div>

    <!-- Columna 2: Soluciones por categoría -->
    <div>
      <h3 class="footer-heading">Soluciones</h3>
      <% if (typeof productosMenu !== 'undefined') {
          const cats = [...new Set(productosMenu.map(p => p.Categoria))];
          cats.forEach(cat => { %>
            <div class="footer-cat-label"><%= cat %></div>
            <ul class="footer-links">
              <% productosMenu.filter(p => p.Categoria === cat).forEach(prod => { %>
                <li><a href="/producto/<%= prod._id || prod.id %>"><%= prod.Nombre %></a></li>
              <% }) %>
            </ul>
      <% })} %>
    </div>

    <!-- Columna 3: Explorar -->
    <div>
      <h3 class="footer-heading">Explorar</h3>
      <ul class="footer-links">
        <li><a href="/">Inicio</a></li>
        <li><a href="/productos">Catálogo de Productos</a></li>
        <li><a href="/noticias">Noticias AgTech</a></li>
        <li><a href="/servicios">Servicios Técnicos</a></li>
        <li><a href="/nosotros">Sobre Nosotros</a></li>
        <li><a href="/contacto">Contáctenos</a></li>
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <span>© <%= year %> Agro Parallel. Todos los derechos reservados.</span>
    <div class="footer-social">
      <a href="https://www.facebook.com/agroparallel" target="_blank" rel="noopener" aria-label="Facebook">
        <i class="fab fa-facebook-f"></i>
      </a>
      <a href="https://www.instagram.com/agro.parallel/" target="_blank" rel="noopener" aria-label="Instagram">
        <i class="fab fa-instagram"></i>
      </a>
      <a href="https://wa.me/5492326403502" target="_blank" rel="noopener" aria-label="WhatsApp">
        <i class="fab fa-whatsapp"></i>
      </a>
    </div>
  </div>
</footer>
