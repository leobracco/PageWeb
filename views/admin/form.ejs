<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= accion %> · Admin — Agro Parallel</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Lora:wght@400;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-body">

  <aside class="admin-sidebar">
    <div class="sidebar-logo">Agro<span>Parallel</span></div>
    <nav class="sidebar-nav">
      <a href="/admin" class="sidebar-link active">📦 Productos</a>
      <a href="/" class="sidebar-link" target="_blank">🌐 Ver Sitio</a>
      <a href="/admin/logout" class="sidebar-link sidebar-logout">⬅ Salir</a>
    </nav>
  </aside>

  <main class="admin-main">
    <header class="admin-topbar">
      <h1 class="admin-page-title"><%= accion %></h1>
      <a href="/admin" class="btn-admin-ghost">← Volver</a>
    </header>

    <% if (error) { %>
      <div class="admin-alert admin-alert-danger"><%= error %></div>
    <% } %>

    <%
      const isEdit = producto !== null;
      const formAction = isEdit ? `/admin/productos/${producto._id || producto.id}` : '/admin/productos';
      const p = producto || {};
      const specs = p.Especificaciones || {};
      const specEntries = Object.entries(specs);
    %>

    <form method="POST" action="<%= formAction %>" class="admin-form">
      <div class="form-grid-2">
        <div class="form-group">
          <label>ID del Producto <span class="text-muted">(slug, ej: AGP-AU-RTK)</span></label>
          <input type="text" name="id" class="admin-input" value="<%= p.id || p._id || '' %>" <%= isEdit ? 'readonly' : 'required' %> placeholder="AGP-NUEVO">
        </div>
        <div class="form-group">
          <label>Nombre *</label>
          <input type="text" name="Nombre" class="admin-input" value="<%= p.Nombre || '' %>" required placeholder="Centrix">
        </div>
      </div>

      <div class="form-grid-2">
        <div class="form-group">
          <label>Categoría *</label>
          <input type="text" name="Categoria" class="admin-input" value="<%= p.Categoria || '' %>" required placeholder="Piloto Automático">
        </div>
        <div class="form-group">
          <label>Precio</label>
          <input type="text" name="Precio" class="admin-input" value="<%= p.Precio || '' %>" placeholder="8.920 + IVA">
        </div>
      </div>

      <div class="form-group">
        <label>Imagen <span class="text-muted">(ruta relativa, ej: assets/img/producto.webp)</span></label>
        <input type="text" name="Imagen" class="admin-input" value="<%= p.Imagen || '' %>" placeholder="assets/img/agp_au_rtk.webp">
      </div>

      <div class="form-group">
        <label>Video <span class="text-muted">(URL embed de YouTube)</span></label>
        <input type="text" name="Video" class="admin-input" value="<%= p.Video || '' %>" placeholder="https://www.youtube.com/embed/...">
      </div>

      <div class="form-group">
        <label>Tags <span class="text-muted">(separados por coma)</span></label>
        <input type="text" name="Tags" class="admin-input" value="<%= (p.Tags || []).join(', ') %>" placeholder="RTK, Precisión 2cm, Máxima Precisión">
      </div>

      <div class="form-group">
        <label>Descripción Corta *</label>
        <textarea name="DescripcionCorta" class="admin-input admin-textarea" rows="2" required><%= p.DescripcionCorta || '' %></textarea>
      </div>

      <div class="form-group">
        <label>Descripción Larga *</label>
        <textarea name="DescripcionLarga" class="admin-input admin-textarea" rows="5" required><%= p.DescripcionLarga || '' %></textarea>
      </div>

      <div class="form-group">
        <label>Especificaciones Técnicas</label>
        <div id="specs-container">
          <% if (specEntries.length > 0) {
               specEntries.forEach(([k, v]) => { %>
            <div class="spec-row">
              <input type="text" name="spec_keys" class="admin-input" value="<%= k %>" placeholder="Precisión">
              <input type="text" name="spec_vals" class="admin-input" value="<%= v %>" placeholder="2 cm (RTK)">
              <button type="button" class="btn-admin-sm btn-admin-danger remove-spec">×</button>
            </div>
          <% })} else { %>
            <div class="spec-row">
              <input type="text" name="spec_keys" class="admin-input" placeholder="Precisión">
              <input type="text" name="spec_vals" class="admin-input" placeholder="2 cm (RTK)">
              <button type="button" class="btn-admin-sm btn-admin-danger remove-spec">×</button>
            </div>
          <% } %>
        </div>
        <button type="button" id="add-spec" class="btn-admin-ghost" style="margin-top:8px">+ Agregar especificación</button>
      </div>

      <hr class="admin-divider">
      <h3 class="admin-section-title">SEO</h3>

      <div class="form-group">
        <label>Título SEO</label>
        <input type="text" name="SEO_Title" class="admin-input" value="<%= (p.SEO || {}).Title || '' %>" placeholder="Centrix | Piloto RTK | Agro Parallel">
      </div>
      <div class="form-group">
        <label>Meta Descripción SEO</label>
        <textarea name="SEO_MetaDescription" class="admin-input admin-textarea" rows="2"><%= (p.SEO || {}).MetaDescription || '' %></textarea>
      </div>

      <div class="form-actions">
        <a href="/admin" class="btn-admin-ghost">Cancelar</a>
        <button type="submit" class="btn-admin-primary"><%= isEdit ? 'Guardar Cambios' : 'Crear Producto' %></button>
      </div>
    </form>
  </main>

  <script>
    document.getElementById('add-spec').addEventListener('click', () => {
      const row = document.createElement('div');
      row.className = 'spec-row';
      row.innerHTML = `<input type="text" name="spec_keys" class="admin-input" placeholder="Clave"><input type="text" name="spec_vals" class="admin-input" placeholder="Valor"><button type="button" class="btn-admin-sm btn-admin-danger remove-spec">×</button>`;
      document.getElementById('specs-container').appendChild(row);
    });
    document.getElementById('specs-container').addEventListener('click', e => {
      if (e.target.classList.contains('remove-spec')) e.target.closest('.spec-row').remove();
    });
  </script>
</body>
</html>
